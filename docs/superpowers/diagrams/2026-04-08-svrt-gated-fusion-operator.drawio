        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="rgb" target="merge">
          <mxGeometry relative="1" as="geometry" />
