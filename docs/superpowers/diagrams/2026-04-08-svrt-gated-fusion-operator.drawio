<mxfile host="app.diagrams.net" modified="2026-04-08T13:35:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="gated-fusion-only" name="GatedFusionOperator">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="GatedFusionOperator: Data Flow &amp; Tensor Shapes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="contract" value="Input (5D path)&#xa;rgb_feat: [B, S, Cr, H, W]&#xa;spike_feat: [B, S, Cs, H, W]&#xa;Output: [B, S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="420" height="120" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="1) Flatten Temporal Axis&#xa;rgb_flat = reshape(rgb_feat) -&gt; [B*S, Cr, H, W]&#xa;spike_flat = reshape(spike_feat) -&gt; [B*S, Cs, H, W]&#xa;fused_in = cat([rgb_flat, spike_flat], dim=1) -&gt; [B*S, Cr+Cs, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="760" height="120" as="geometry" />
        </mxCell>

        <mxCell id="fuse" value="2a) Fuse Branch&#xa;Conv3x3(Cr+Cs -&gt; hidden)&#xa;ReLU&#xa;Conv1x1(hidden -&gt; Co)&#xa;fuse: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="420" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="2b) Gate Branch&#xa;Conv3x3(Cr+Cs -&gt; hidden)&#xa;ReLU&#xa;Conv1x1(hidden -&gt; Co)&#xa;Sigmoid&#xa;gate: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="320" y="420" width="240" height="170" as="geometry" />
        </mxCell>
        <mxCell id="rgb" value="2c) RGB Shortcut&#xa;rgb_base = Conv1x1(Cr -&gt; Co)(rgb_flat)&#xa;rgb_base: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="600" y="420" width="200" height="170" as="geometry" />
        </mxCell>

        <mxCell id="merge" value="3) Gated Merge&#xa;out_flat = rgb_base + gate * fuse&#xa;shape: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="210" y="650" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="restore" value="4) Restore Sequence Layout&#xa;out = reshape(out_flat) -&gt; [B, S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="210" y="780" width="420" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note4d" value="4D path in code&#xa;Input [B, Cr, H, W] + [B, Cs, H, W]&#xa;Same branch logic, no temporal reshape&#xa;Output [B, Co, H, W]" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="420" width="290" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="contract" target="s1">
