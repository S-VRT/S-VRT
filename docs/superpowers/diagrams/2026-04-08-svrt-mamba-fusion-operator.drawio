        <mxCell id="e_spike_flat" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="spike_in" target="spike_flat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_spike_encoder" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="spike_flat" target="spike_encoder">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_spike_low" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="spike_encoder" target="spike_low">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_rgb_pack" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="rgb_low" target="pack">
          <mxGeometry relative="1" as="geometry" />
