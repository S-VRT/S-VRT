        <mxCell id="e_adapter_rgb" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="adapter" target="rgb_in">
          <mxGeometry relative="1" as="geometry" />
