        <mxCell id="e_heads_upsample" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="heads" target="upsample">
          <mxGeometry relative="1" as="geometry" />
