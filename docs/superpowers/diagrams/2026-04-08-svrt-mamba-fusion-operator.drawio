        <mxCell id="e_rgb_encoder" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="rgb_flat" target="rgb_encoder">
          <mxGeometry relative="1" as="geometry" />
