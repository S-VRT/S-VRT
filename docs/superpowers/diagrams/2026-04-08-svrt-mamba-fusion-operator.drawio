        <mxCell id="e_mixer_writeback" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="mixer" target="writeback">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_writeback_heads" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="writeback" target="heads">
          <mxGeometry relative="1" as="geometry" />
