        <mxCell id="e_spike_pack" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="spike_low" target="pack">
          <mxGeometry relative="1" as="geometry" />
