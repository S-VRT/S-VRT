        <mxCell id="e_pack_mixer" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeWidth=2;" edge="1" parent="1" source="pack" target="mixer">
          <mxGeometry relative="1" as="geometry" />
