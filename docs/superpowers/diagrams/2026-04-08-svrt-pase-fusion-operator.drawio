        <mxCell id="title" value="PaseFusionOperator: Data Flow &amp; Tensor Shapes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="40" as="geometry" />
        </mxCell>
        <mxCell id="contract" value="Input (5D path)&#xa;rgb_feat: [B, S, Cr, H, W]&#xa;spike_feat: [B, S, Cs, H, W]&#xa;Output: [B, S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="420" height="120" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="1) Flatten Temporal Axis&#xa;rgb_flat = reshape(rgb_feat) -&gt; [B*S, Cr, H, W]&#xa;spike_flat = reshape(spike_feat) -&gt; [B*S, Cs, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="240" width="760" height="100" as="geometry" />
        </mxCell>

        <mxCell id="rgb_branch" value="2a) RGB Branch&#xa;rgb_proj = Conv1x1(Cr -&gt; Co)(rgb_flat)&#xa;shape: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="330" height="120" as="geometry" />
        </mxCell>
        <mxCell id="spk_branch" value="2b) Spike Branch&#xa;pase_out = PixelAdaptiveSpikeEncoder(Cs -&gt; Co)(spike_flat)&#xa;shape: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="470" y="400" width="330" height="120" as="geometry" />
        </mxCell>

        <mxCell id="merge" value="3) Additive Fusion&#xa;fused_flat = rgb_proj + pase_out&#xa;shape: [B*S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="220" y="580" width="400" height="90" as="geometry" />
        </mxCell>
        <mxCell id="restore" value="4) Restore Sequence Layout&#xa;fused = reshape(fused_flat) -&gt; [B, S, Co, H, W]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="220" y="720" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note_4d" value="4D path in code&#xa;Input [B, Cr, H, W] + [B, Cs, H, W]&#xa;No temporal flatten/restore&#xa;Output = rgb_proj(rgb_feat) + pase(spike_feat)&#xa;shape: [B, Co, H, W]" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="860" y="400" width="300" height="150" as="geometry" />
